<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📚 Профиль"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/library_primary"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvProfileRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔑 Роль: "
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvProfileEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Email: "
        android:textSize="18sp"
        android:layout_marginBottom="32dp"/>

    <!-- ✅ КНОПКА ДЛЯ ТЕСТОВЫХ ДАННЫХ (видна только в отладке) -->
    <Button
        android:id="@+id/btnDebugTest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧪 Создать тест: штрафы"
        android:backgroundTint="@color/library_accent"
        android:textColor="@color/library_primary_dark"
        android:layout_marginBottom="16dp"
        android:visibility="gone"/>  <!-- По умолчанию скрыта -->

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🚪 Выйти"
        style="@style/LibraryButton.Destructive"/>

</LinearLayout>