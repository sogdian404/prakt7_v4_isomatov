<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/library_surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="200dp"
        android:layout_height="300dp"
        android:layout_gravity="center"
        android:padding="12dp"
        android:background="@drawable/card_border">

        <!-- Обложка с рамкой -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/coverContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.65"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/library_accent"
            app:strokeWidth="2dp">

            <ImageView
                android:id="@+id/ivBookCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/library_primary"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Название -->
        <TextView
            android:id="@+id/tvBookTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Название книги"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/library_text"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/coverContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <!-- Автор -->
        <TextView
            android:id="@+id/tvBookAuthor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Автор"
            android:textSize="13sp"
            android:textColor="@color/library_text_secondary"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvBookTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Статус (бейдж) -->
        <TextView
            android:elevation="8dp"
            android:translationZ="8dp"
            android:id="@+id/tvBookType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚 Печатная"
            android:textSize="11sp"
            app:chipBackgroundColor="@color/status_available"
            app:chipCornerRadius="16dp"
            android:textColor="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>