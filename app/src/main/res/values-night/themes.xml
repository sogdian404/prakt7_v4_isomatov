<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 🌙 Тёмная тема -->
    <style name="Theme.LibraryApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Цвета -->
        <item name="colorPrimary">@color/library_primary</item>
        <item name="colorPrimaryVariant">@color/library_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/library_accent</item>
        <item name="colorSecondaryVariant">@color/library_primary_dark</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Фон -->
        <item name="android:windowBackground">@color/library_background</item>
        <item name="android:colorBackground">@color/library_background</item>

        <!-- Текст -->
        <item name="android:textColorPrimary">@color/library_text</item>
        <item name="android:textColorSecondary">@color/library_text_secondary</item>

        <!-- ActionBar -->
        <item name="actionBarStyle">@style/LibraryActionBar.Dark</item>

        <!-- Кнопки -->
        <item name="materialButtonStyle">@style/LibraryButton.Dark</item>
    </style>

    <!-- 📚 Стиль ActionBar (тёмный) -->
    <style name="LibraryActionBar.Dark" parent="Widget.MaterialComponents.ActionBar.Primary">
        <item name="background">@color/library_primary_dark</item>
        <item name="titleTextColor">@color/white</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- 🔘 Стиль кнопок (тёмный) -->
    <style name="LibraryButton.Dark" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/library_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">2dp</item>
    </style>

    <!-- 🗑️ Стиль кнопки удаления -->
    <style name="LibraryButton.Destructive" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/status_overdue</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- ✨ Стиль акцентной кнопки -->
    <style name="LibraryButton.Accent" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/library_accent</item>
        <item name="android:textColor">@color/library_primary_dark</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>